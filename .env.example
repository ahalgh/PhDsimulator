# Optional: GitHub Personal Access Token (for private repos and higher rate limits)
GITHUB_TOKEN=

# Optional: ORCID API credentials (for trusted-party access)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# Optional: SerpAPI key (for Google Scholar data)
SERPAPI_KEY=

# Google Service Account (for Tasks and Calendar integration)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional: User email for Google Tasks domain-wide delegation (Workspace only)
GOOGLE_TASKS_USER_EMAIL=
